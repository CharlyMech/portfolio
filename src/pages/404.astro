---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found">
  <div class="flex flex-col items-center justify-center min-h-[60vh] p-10 text-center">
    <p class="label-mono text-accent mb-4">ERROR_404</p>
    <h1 class="text-display leading-none text-foreground/10 mb-6">
      404
    </h1>
    <p class="text-body text-foreground-secondary mb-8 max-w-sm">
      This page doesn't exist or has been moved to a different sector.
    </p>
    <a href="/" class="btn-primary">← Return to base</a>
  </div>
</BaseLayout>
