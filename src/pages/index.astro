---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/sections/HeroSection";
import InfrastructureSection from "@/components/sections/InfrastructureSection";
import GitHubActivitySection from "@/components/sections/GitHubActivitySection.astro";
import CTASection from "@/components/sections/CTASection";
import { fetchGitHubActivity } from "@/core/services/githubService";

const ghData = await fetchGitHubActivity();
const topLanguages = ghData?.topLanguages ?? [];
---

<BaseLayout>
	<!-- Hero: two-col grid -->
	<HeroSection client:load />

	<!-- Core infrastructure + experience log + language pie -->
	<InfrastructureSection topLanguages={topLanguages} client:visible />

	<!-- GitHub activity dashboard -->
	<GitHubActivitySection />

	<!-- CTA / contact teaser -->
	<CTASection client:visible />
</BaseLayout>
