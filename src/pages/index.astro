---
import BaseLayout from "@/layouts/BaseLayout.astro";
import HeroSection from "@/components/sections/HeroSection";
import InfrastructureSection from "@/components/sections/InfrastructureSection";
import GitHubActivitySection from "@/components/sections/GitHubActivitySection";
import CTASection from "@/components/sections/CTASection";
---

<BaseLayout section="home">
	<!-- Hero: two-col grid -->
	<HeroSection client:load />

	<!-- Core infrastructure + experience log + language pie -->
	<InfrastructureSection client:visible />

	<!-- GitHub activity dashboard: client:load so fetch runs on first paint, not only when scrolled into view -->
	<GitHubActivitySection client:load />

	<!-- CTA / contact teaser -->
	<CTASection client:visible />
</BaseLayout>
