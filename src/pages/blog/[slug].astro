---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { BLOG_POSTS } from '@/data/portfolio';

export async function getStaticPaths() {
  return BLOG_POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout
  title={`${post.title} — Carlos Dev`}
  description={post.excerpt}
>
  <article class="px-6 md:px-10 py-10 max-w-[860px]">
    <div class="border-b border-border pb-6 mb-8">
      <p class="label-mono text-accent mb-3">// Field Note</p>
      <h1 class="font-display font-black text-[clamp(2.5rem,6vw,4rem)] leading-none tracking-tight mb-4">
        {post.title}
      </h1>
      <div class="flex items-center gap-3">
        <span class="label-mono text-text-muted">{post.date}</span>
        <span class="label-mono text-text-muted">•</span>
        <span class="label-mono text-text-muted">{post.readTime}</span>
      </div>
    </div>

    <div class="space-y-6">
      {post.content.map((paragraph) => (
        <p class="font-body text-base text-text-secondary leading-relaxed">
          {paragraph}
        </p>
      ))}
    </div>

    <div class="mt-10 flex flex-wrap gap-2">
      {post.tags.map((tag) => (
        <span class="tech-tag">{tag}</span>
      ))}
    </div>

    <div class="mt-10">
      <a href="/blog" class="btn-outline text-xs">
        ← Back to blog
      </a>
    </div>
  </article>
</BaseLayout>
