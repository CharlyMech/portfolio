---
import type { BlogPost } from '@/core/models/blog';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { BLOG_POSTS } from '@/constants/blog';

export async function getStaticPaths() {
  return BLOG_POSTS.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: BlogPost; }
const { post } = Astro.props;
---

<BaseLayout
  title={`${post.title} — Carlos Sánchez Recio`}
  description={post.excerpt}
  ogType="article"
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.excerpt,
    "datePublished": post.date,
    "author": {
      "@type": "Person",
      "name": "Carlos Sánchez Recio",
      "url": "https://charlymech.com"
    },
    "url": `https://charlymech.com/blog/${post.slug}`,
    "keywords": post.tags.join(", ")
  })} />
  <article class="px-6 md:px-10 py-10 max-w-[860px]">
    <div class="border-b border-border pb-6 mb-8">
      <p class="label-mono text-accent mb-3">// Field Note</p>
      <h1 class="text-heading-page mb-4">
        {post.title}
      </h1>
      <div class="flex items-center gap-3">
        <span class="label-mono text-foreground-muted">{post.date}</span>
        <span class="label-mono text-foreground-muted">•</span>
        <span class="label-mono text-foreground-muted">{post.readTime}</span>
      </div>
    </div>

    <div class="space-y-6">
      {post.content.map((paragraph) => (
        <p class="text-body text-foreground-secondary">
          {paragraph}
        </p>
      ))}
    </div>

    <div class="mt-10 flex flex-wrap gap-2">
      {post.tags.map((tag) => (
        <span class="tech-tag">{tag}</span>
      ))}
    </div>

    <div class="mt-10">
      <a href="/blog" class="btn-outline text-xs">
        ← Back to blog
      </a>
    </div>
  </article>
</BaseLayout>
