---
/**
 * PageHeader — Reusable section header for inner pages
 * Shows breadcrumb label, title, and optional subtitle
 */
interface Props {
  label: string;
  title: string;
  subtitle?: string;
}

const { label, title, subtitle } = Astro.props;
---

<header class="border-b border-border px-6 sm:px-8 md:px-10 py-8">
  <p class="label-mono text-accent mb-2">{label}</p>
  <h1 class="font-display font-black text-[clamp(2.5rem,6vw,4.5rem)] leading-none tracking-tight">
    {title}
  </h1>
  {subtitle && (
    <p class="font-body text-sm text-text-secondary mt-4 max-w-xl leading-relaxed">
      {subtitle}
    </p>
  )}
</header>
