---
import TopNav from "@/components/navigation/TopNav";
import Sidebar from "@/components/navigation/Sidebar";
import BottomNav from "@/components/navigation/BottomNav";
import { Toaster } from "@/components/ui/sonner";
import "@/styles/global.css";
import "@/bones/registry";
import { SITE_META } from "@/constants/profile";
import { en } from "@/i18n/en";
import { es } from "@/i18n/es";
import { ViewTransitions, ClientRouter } from "astro:transitions";

type Section = "home" | "projects" | "contact" | "experience" | "services";

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: "website" | "article";
	section?: Section;
}

const BASE_NAME = "Carlos Sánchez Recio";

const SECTION_LABELS: Record<Section, { en: string; es: string }> = {
	home: { en: "", es: "" },
	projects: { en: "Projects", es: "Proyectos" },
	contact: { en: "Contact", es: "Contacto" },
	experience: { en: "Career", es: "Experiencia y estudios" },
	services: { en: "Freelance services", es: "Servicios freelance" },
};

const SECTION_DESCRIPTIONS: Record<Section, { en: string; es: string }> = {
	home: { en: en.site.description, es: es.site.description },
	projects: {
		en: en.projects.pageDescription,
		es: es.projects.pageDescription,
	},
	contact: {
		en: en.contact.pageDescription,
		es: es.contact.pageDescription,
	},
	experience: {
		en: en.experience.pageDescription,
		es: es.experience.pageDescription,
	},
	services: {
		en: en.services.pageDescription,
		es: es.services.pageDescription,
	},
};

const {
	ogImage = SITE_META.ogImage,
	ogType = "website",
	section = "home",
} = Astro.props;

const sectionLabels = SECTION_LABELS[section];
const computedTitle =
	section === "home"
		? BASE_NAME
		: `${BASE_NAME} | ${sectionLabels.en}`;
const title = Astro.props.title ?? computedTitle;
const description =
	Astro.props.description ?? SECTION_DESCRIPTIONS[section].en;

const currentPath = Astro.url.pathname;
const canonicalURL = new URL(Astro.url.pathname, SITE_META.url).toString();
const ogImageURL = new URL(ogImage, SITE_META.url).toString();
---

<!doctype html>
<html lang="en" data-theme="dark" id="html-root">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0d0d0d" />
		<meta name="author" content="Carlos Sánchez Recio" />
		<meta
			name="robots"
			content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
		/>
		<meta name="googlebot" content="index, follow" />
		<meta name="page-section" content={section} />

		<!-- OG / Social -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content={ogType} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />
		<meta name="twitter:creator" content="@charlymech" />
		<meta name="twitter:site" content="@charlymech" />

		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL} />
		<link rel="alternate" hreflang="en" href={canonicalURL} />
		<link rel="alternate" hreflang="es" href={canonicalURL} />
		<link rel="alternate" hreflang="x-default" href={canonicalURL} />

		<!-- Sync html[lang] + document.title + description meta from persisted locale -->
		<script
			is:inline
			define:vars={{
				baseName: BASE_NAME,
				labels: SECTION_LABELS,
				descriptions: SECTION_DESCRIPTIONS,
			}}
		>
			(function () {
				window.__portfolioTitleLabels = labels;
				window.__portfolioTitleBase = baseName;
				window.__portfolioDescriptions = descriptions;
				if (window.__portfolioTitleInit) {
					window.__portfolioApplyMeta &&
						window.__portfolioApplyMeta();
					return;
				}
				window.__portfolioTitleInit = true;
				function readLocale() {
					try {
						var stored = JSON.parse(
							localStorage.getItem("portfolio-locale") || "{}"
						);
						return (stored.state && stored.state.locale) || "en";
					} catch (_) {
						return "en";
					}
				}
				function readSection() {
					var m = document.querySelector(
						'meta[name="page-section"]'
					);
					return (m && m.getAttribute("content")) || "home";
				}
				function setMeta(selector, value) {
					var el = document.querySelector(selector);
					if (el && value != null) el.setAttribute("content", value);
				}
				function applyMeta() {
					var locale = readLocale();
					var section = readSection();
					var loc = locale === "es" ? "es" : "en";
					var lbls = window.__portfolioTitleLabels;
					var descs = window.__portfolioDescriptions;
					var base = window.__portfolioTitleBase;
					var label = lbls[section] && lbls[section][loc];
					var title = label ? base + " | " + label : base;
					document.title = title;
					document
						.getElementById("html-root")
						.setAttribute("lang", locale);
					var desc = descs[section] && descs[section][loc];
					if (desc) {
						setMeta('meta[name="description"]', desc);
						setMeta('meta[property="og:description"]', desc);
						setMeta('meta[name="twitter:description"]', desc);
					}
					setMeta('meta[property="og:title"]', title);
					setMeta('meta[name="twitter:title"]', title);
				}
				window.__portfolioApplyMeta = applyMeta;
				applyMeta();
				document.addEventListener(
					"portfolio:locale-change",
					applyMeta
				);
				document.addEventListener("astro:after-swap", applyMeta);
			})();
		</script>
		<!-- Sync data-theme from persisted preference before first paint (prevents flash) -->
		<script is:inline>
			(function () {
				try {
					var stored = JSON.parse(
						localStorage.getItem("portfolio-theme") || "{}"
					);
					var theme = stored.state && stored.state.theme;
					if (theme)
						document
							.getElementById("html-root")
							.setAttribute("data-theme", theme);
				} catch (_) {}
			})();
		</script>
		<!-- Re-apply theme after each view transition swap (html attr resets to SSR default) -->
		<script is:inline>
			document.addEventListener("astro:after-swap", function () {
				try {
					var stored = JSON.parse(
						localStorage.getItem("portfolio-theme") || "{}"
					);
					var theme = stored.state && stored.state.theme;
					if (theme)
						document
							.getElementById("html-root")
							.setAttribute("data-theme", theme);
				} catch (_) {}
			});
		</script>
		<ViewTransitions />

		<!-- Preload fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<!-- JSON-LD: Person schema (sitewide) -->
		<script
			is:inline
			type="application/ld+json"
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "Person",
				name: "Carlos Sánchez Recio",
				alternateName: "CharlyMech",
				url: "https://charlymech.com",
				jobTitle: [
					"Software Engineer",
					"Mobile Developer",
					"Full Stack Developer",
					"Flutter Developer",
					"React Native Developer",
				],
				description: SITE_META.description,
				address: {
					"@type": "PostalAddress",
					addressLocality: "Valladolid",
					addressCountry: "ES",
				},
				sameAs: [
					"https://github.com/charlymech",
					"https://linkedin.com/in/carlos-sanchezrecio-dev/",
				],
				knowsAbout: [
					"Flutter",
					"React Native",
					"Expo",
					"React",
					"Next.js",
					"NestJS",
					"Python",
					"TypeScript",
					"Node.js",
					"Data Analysis",
					"Mobile Development",
					"Full Stack Development",
					"Software Architecture",
				],
			})}
		/>

		<slot name="head" />
	</head>

	<body class="grain bg-background text-foreground">
		<!-- Sidebar (desktop only — fixed left rail) -->
		<Sidebar currentPath={currentPath} client:load transition:persist />

		<!-- Main layout shell -->
		<div class="flex flex-col min-h-screen
             md:pl-[48px]">
			<!-- Top navigation bar -->
			<TopNav currentPath={currentPath} client:load transition:persist />

			<!-- Scrollable main content -->
			<!--
        pt = nav height (56px)
        pb = bottom nav height on mobile (68px)
        The bottom-nav must NOT overlap content — padding handles this.
      -->
			<main
				id="main-content"
				class="flex-1 overflow-y-auto
               pt-[56px]
               pb-[68px] md:pb-0"
			>
				<!-- Inner container with max-width and grid border styling -->
				<div
					class="min-h-full border-x border-border mx-auto max-w-[1280px]"
				>
					<slot />
				</div>
			</main>
		</div>

		<!-- Mobile bottom navigation (fixed, rendered outside main) -->
		<BottomNav currentPath={currentPath} client:load transition:persist />
		<Toaster client:load />
		<ClientRouter />
	</body>
</html>
